# ── LLM Provider: openai | openrouter | anthropic | ollama | vllm ──
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# OpenRouter (dev-friendly, access to many models)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local)
# OLLAMA_MODEL=qwen2.5-coder

# vLLM (self-hosted)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# VLLM_API_KEY=EMPTY

# ── Agent config ──
MAX_ITERATIONS=8
CONFIDENCE_THRESHOLD=0.55
WORKSPACE_ROOT=/absolute/path/to/your/project

# ── Security ──
JWT_SECRET=change-me-in-production

# ── Checkpoint (sqlite | memory) ──
# CHECKPOINT_BACKEND=sqlite
# CHECKPOINT_DB=checkpoints.db

# ── Audit DB (optional, defaults to audit.jsonl) ──
# AUDIT_DB_URL=postgresql://user:pass@localhost:5432/audit
